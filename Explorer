-- Garante que o script rode na CoreGui (padrão de executor) ou na PlayerGui caso dê erro
local parent = game:GetService("CoreGui") or game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")

-- Evita duplicar o script se você clonar de novo
if parent:FindFirstChild("RobloxExplorerSim") then
    parent.RobloxExplorerSim:Destroy()
end

-- --- CRIAÇÃO DA INTERFACE ---
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "RobloxExplorerSim"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = parent

-- Frame Principal (O painel do canto)
local MainFrame = Instance.new("Frame")
MainFrame.Name = "MainFrame"
MainFrame.Size = UDim2.new(0, 250, 0, 400)
MainFrame.Position = UDim2.new(0, 10, 0.5, -200)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.BorderSizePixel = 0
MainFrame.Active = true
MainFrame.Draggable = true -- Deixa você arrastar o explorer pela tela
MainFrame.Parent = ScreenGui

-- Título do Painel
local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 30)
Title.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
Title.Text = "  Roblox Explorer (Sim)"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextXAlignment = Enum.TextXAlignment.Left
Title.Font = Enum.Font.SourceSansBold
Title.TextSize = 16
Title.Parent = MainFrame

-- Container com Scroll (Lista dos objetos)
local Container = Instance.new("ScrollingFrame")
Container.Size = UDim2.new(1, 0, 1, -30)
Container.Position = UDim2.new(0, 0, 0, 30)
Container.BackgroundTransparency = 1
Container.CanvasSize = UDim2.new(0, 0, 0, 0)
Container.ScrollBarThickness = 6
Container.Parent = MainFrame

-- Layout automático para empilhar os itens
local UIListLayout = Instance.new("UIListLayout")
UIListLayout.Parent = Container
UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder

-- Atualiza o tamanho do scroll conforme os itens aparecem
UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    Container.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y)
end)

-- --- LÓGICA DO EXPLORER ---

-- Função mágica que cria as linhas do Explorer (Recursiva)
local function CriarItemExplorer(object, indentLevel)
    -- Frame da linha atual
    local Row = Instance.new("Frame")
    Row.Name = object.Name
    Row.Size = UDim2.new(1, 0, 0, 24)
    Row.BackgroundTransparency = 1
    Row.Parent = Container
    
    -- Setinha para abrir/fechar
    local ToggleBtn = Instance.new("TextButton")
    ToggleBtn.Size = UDim2.new(0, 20, 1, 0)
    ToggleBtn.Position = UDim2.new(0, indentLevel * 15, 0, 0)
    ToggleBtn.BackgroundTransparency = 1
    ToggleBtn.Text = #object:GetChildren() > 0 and ">" or " "
    ToggleBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    ToggleBtn.Font = Enum.Font.SourceSansBold
    ToggleBtn.TextSize = 14
    ToggleBtn.Parent = Row
    
    -- Nome do Objeto
    local NameLabel = Instance.new("TextLabel")
    NameLabel.Size = UDim2.new(1, -(25 + (indentLevel * 15)), 1, 0)
    NameLabel.Position = UDim2.new(0, 25 + (indentLevel * 15), 0, 0)
    NameLabel.BackgroundTransparency = 1
    NameLabel.Text = object.Name .. " (" .. object.ClassName .. ")"
    NameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    NameLabel.TextXAlignment = Enum.TextXAlignment.Left
    NameLabel.Font = Enum.Font.SourceSans
    NameLabel.TextSize = 14
    NameLabel.Parent = Row

    local subRows = {}
    local aberto = false

    -- Clique na setinha pra abrir e fechar os filhos
    ToggleBtn.MouseButton1Click:Connect(function()
        if #object:GetChildren() == 0 then return end
        
        aberto = not aberto
        if aberto then
            ToggleBtn.Text = "v" -- Setinha pra baixo
            -- Cria os filhos na árvore
            for _, child in ipairs(object:GetChildren()) do
                local childRow = CriarItemExplorer(child, indentLevel + 1)
                table.insert(subRows, childRow)
                
                -- Gambiarra organizada: move o filho pra ficar logo abaixo do pai na UI
                childRow.LayoutOrder = Row.LayoutOrder + 1
            end
        else
            ToggleBtn.Text = ">" -- Setinha pro lado de novo
            -- Apaga os filhos da tela
            for _, subRow in ipairs(subRows) do
                if subRow then subRow:Destroy() end
            end
            subRows = {}
        end
    end)

    return Row
end

-- --- CARREGAR OS SERVIÇOS PRINCIPAIS ---
local servicos = {
    game:GetService("Workspace"),
    game:GetService("Players"),
    game:GetService("Lighting"),
    game:GetService("ReplicatedStorage"),
    game:GetService("ServerStorage"), -- Se for localscript de executor, aqui pode vir vazio
    game:GetService("StarterGui"),
    game:GetService("StarterPack"),
    game:GetService("SoundService")
}

-- Renderiza os serviços no painel
for i, service in ipairs(servicos) do
    if service then
        local row = CriarItemExplorer(service, 0)
        row.LayoutOrder = i * 1000 -- Garante espaçamento pros filhos entrarem no meio
    end
end
