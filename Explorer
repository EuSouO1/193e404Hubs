-- --- JANELA DO VISUALIZADOR DE CÓDIGO (SCRIPT VIEWER) ---
local function AbrirScriptViewer(scriptName, scriptSource)
    if ScreenGui:FindFirstChild("ScriptViewer") then
        ScreenGui.ScriptViewer:Destroy()
    end

    local ViewerFrame = Instance.new("Frame")
    ViewerFrame.Name = "ScriptViewer"
    ViewerFrame.Size = UDim2.new(0, 500, 0, 350)
    ViewerFrame.Position = UDim2.new(0.5, -250, 0.5, -175)
    ViewerFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    ViewerFrame.BorderSizePixel = 0
    ViewerFrame.Active = true
    ViewerFrame.Draggable = true
    ViewerFrame.Parent = ScreenGui

    local VTitle = Instance.new("TextLabel")
    VTitle.Size = UDim2.new(1, -70, 0, 35)
    VTitle.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    VTitle.Text = "  Código: " .. scriptName
    VTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
    VTitle.TextXAlignment = Enum.TextXAlignment.Left
    VTitle.Font = Enum.Font.SourceSansBold
    VTitle.TextSize = 14
    VTitle.Parent = ViewerFrame

    -- Botão de Copiar
    local CopyBtn = Instance.new("TextButton")
    CopyBtn.Size = UDim2.new(0, 70, 0, 35)
    CopyBtn.Position = UDim2.new(1, -105, 0, 0)
    CopyBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
    CopyBtn.Text = "Copiar"
    CopyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    CopyBtn.Font = Enum.Font.SourceSansBold
    CopyBtn.TextSize = 14
    CopyBtn.Parent = ViewerFrame

    CopyBtn.MouseButton1Click:Connect(function()
        if setclipboard then
            setclipboard(scriptSource)
            CopyBtn.Text = "Copiado!"
            task.wait(1)
            CopyBtn.Text = "Copiar"
        else
            CopyBtn.Text = "Sem Executor"
        end
    end)

    -- Botão de Fechar (X)
    local CloseBtn = Instance.new("TextButton")
    CloseBtn.Size = UDim2.new(0, 35, 0, 35)
    CloseBtn.Position = UDim2.new(1, -35, 0, 0)
    CloseBtn.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
    CloseBtn.Text = "X"
    CloseBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    CloseBtn.Font = Enum.Font.SourceSansBold
    CloseBtn.TextSize = 14
    CloseBtn.Parent = ViewerFrame

    CloseBtn.MouseButton1Click:Connect(function()
        ViewerFrame:Destroy()
    end)

    -- Area com Scroll para o Texto do código
    local TextScroll = Instance.new("ScrollingFrame")
    TextScroll.Size = UDim2.new(1, -10, 1, -45)
    TextScroll.Position = UDim2.new(0, 5, 0, 40)
    TextScroll.BackgroundTransparency = 1
    TextScroll.ScrollBarThickness = 6
    TextScroll.Parent = ViewerFrame

    local SourceLabel = Instance.new("TextLabel")
    SourceLabel.Size = UDim2.new(1, 0, 0, 0)
    SourceLabel.BackgroundTransparency = 1
    SourceLabel.Text = scriptSource
    SourceLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
    SourceLabel.TextXAlignment = Enum.TextXAlignment.Left
    SourceLabel.TextYAlignment = Enum.TextYAlignment.Top
    SourceLabel.Font = Enum.Font.Code
    SourceLabel.TextSize = 13
    SourceLabel.TextWrapped = true
    SourceLabel.Parent = TextScroll

    -- Ajusta o tamanho do Scroll de acordo com o tamanho do texto do código
    SourceLabel:GetPropertyChangedSignal("TextBounds"):Connect(function()
        SourceLabel.Size = UDim2.new(1, 0, 0, SourceLabel.TextBounds.Y + 20)
        TextScroll.CanvasSize = UDim2.new(0, 0, 0, SourceLabel.TextBounds.Y + 20)
    end)
end

-- --- FUNÇÃO QUE CRIA AS LINHAS DA ÁRVORE (RECURSIVA) ---
local globalOrder = 0

local function CriarItemExplorer(object, indentLevel, parentOrder)
    globalOrder = globalOrder + 1
    local currentOrder = parentOrder * 10000 + globalOrder

    local Row = Instance.new("Frame")
    Row.Name = object.Name
    Row.Size = UDim2.new(1, 0, 0, 24)
    Row.BackgroundTransparency = 1
    Row.LayoutOrder = currentOrder
    Row.Parent = Container
    
    -- Seta para abrir/fechar
    local ToggleBtn = Instance.new("TextButton")
    ToggleBtn.Size = UDim2.new(0, 20, 1, 0)
    ToggleBtn.Position = UDim2.new(0, indentLevel * 12, 0, 0)
    ToggleBtn.BackgroundTransparency = 1
    ToggleBtn.Text = #object:GetChildren() > 0 and ">" or " "
    ToggleBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    ToggleBtn.Font = Enum.Font.SourceSansBold
    ToggleBtn.TextSize = 14
    ToggleBtn.Parent = Row
    
    -- Nome do Objeto
    local NameLabel = Instance.new("TextLabel")
    local extraSpace = (object:IsA("LuaSourceContainer")) and 45 or 25
    NameLabel.Size = UDim2.new(1, -(extraSpace + (indentLevel * 12)), 1, 0)
    NameLabel.Position = UDim2.new(0, 25 + (indentLevel * 12), 0, 0)
    NameLabel.BackgroundTransparency = 1
    NameLabel.Text = object.Name .. " [" .. object.ClassName .. "]"
    NameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    NameLabel.TextXAlignment = Enum.TextXAlignment.Left
    NameLabel.Font = Enum.Font.SourceSans
    NameLabel.TextSize = 14
    NameLabel.Parent = Row

    -- Se for script, bota o botão de + pra ler o código
    if object:IsA("LuaSourceContainer") then
        local ScriptBtn = Instance.new("TextButton")
        ScriptBtn.Size = UDim2.new(0, 20, 0, 20)
        ScriptBtn.Position = UDim2.new(1, -25, 0, 2)
        ScriptBtn.BackgroundColor3 = Color3.fromRGB(50, 120, 50)
        ScriptBtn.Text = "+"
        ScriptBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        ScriptBtn.Font = Enum.Font.SourceSansBold
        ScriptBtn.TextSize = 14
        ScriptBtn.Parent = Row

        ScriptBtn.MouseButton1Click:Connect(function()
            -- Tenta ler o código (Geralmente precisa de decompiler ou executor bom pra ler .Source)
            local src = "-- Não foi possível ler o código desse script (Proteção do Roblox ou do Executor)"
            local pcallSuccess, pcallErr = pcall(function()
                src = object.Source
            end)
            if not pcallSuccess or src == "" then
                src = "-- [Erro ou Script Vazio]\n-- Nota: Alguns executores precisam do comando decompile(script) para ler scripts do jogo."
            end
            AbrirScriptViewer(object.Name, src)
        end)
    end

    local subRows = {}
    local aberto = false

    ToggleBtn.MouseButton1Click:Connect(function()
        if #object:GetChildren() == 0 then return end
        
        aberto = not aberto
        if aberto then
            ToggleBtn.Text = "v"
            -- Cria os filhos e bota eles com a ordem logo abaixo do pai
            for _, child in ipairs(object:GetChildren()) do
                local childRow = CriarItemExplorer(child, indentLevel + 1, currentOrder)
                table.insert(subRows, childRow)
            end
        else
            ToggleBtn.Text = ">"
            -- Função limpa-tudo recursiva pra sumir com os filhos e netos da tela
            local function limpar(rows)
                for _, subRow in ipairs(rows) do
                    if subRow then
                        subRow:Destroy()
                    end
                end
            end
            limpar(subRows)
            subRows = {}
        end
    end)

    return Row
end

-- --- CARREGAR OS SERVIÇOS PRINCIPAIS ---
local servicos = {
    game:GetService("Workspace"),
    game:GetService("Players"),
    game:GetService("Lighting"),
    game:GetService("ReplicatedStorage"),
    game:GetService("StarterGui"),
    game:GetService("StarterPack"),
    game:GetService("SoundService")
}

for i, service in ipairs(servicos) do
    if service then
        CriarItemExplorer(service, 0, i)
    end
end
