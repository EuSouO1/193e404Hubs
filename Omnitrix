-- === DETECÇÃO DE COMBOS DE SETAS (MASTER CONTROL / AUTO-DESTRUIÇÃO) ===
local function verificarCombos(tecla)
    local agora = os.clock()
    if agora - lastComboClickTime > 4.0 then
        comboHistory = ""
    end
    lastComboClickTime = agora
    comboHistory = comboHistory .. tecla
    
    if string.sub(comboHistory, -4) == "CBBB" then
        comboHistory = ""
        masterControlActive = not masterControlActive
        if masterControlActive then
            shoutInChat("Master Control Ativado")
            MainPanel.BackgroundColor3 = CORES_PAINEL.Carregado
            omnitrixCooldown = false
            if isTransformed then
                SelectionPanel.Visible = true
                SilhouetteImg.Text = ListaAliensDisponiveis[currentAlienIndex].Emoji
            end
        else
            shoutInChat("Master Control Desativado")
            if isTransformed then
                startOmnitrixCooldown()
            end
        end
    elseif string.sub(comboHistory, -4) == "BBCC" then
        comboHistory = ""
        masterControlActive = false 
        
        MainPanel.BackgroundColor3 = CORES_PAINEL.AutoDestruicao
        
        local TimerLbl = Instance.new("TextLabel", ScreenGui)
        TimerLbl.Size = UDim2.new(0, 300, 0, 50)
        TimerLbl.Position = UDim2.new(0.5, -150, 0.1, 0)
        TimerLbl.TextColor3 = Color3.new(1,0,0); TimerLbl.TextSize = 40;
        TimerLbl.ZIndex = 6
        TimerLbl.BackgroundTransparency = 1
        
        for i = 20, 1, -1 do
            TimerLbl.Text = "AUTO-DESTRUIÇÃO: " .. i
            pcall(function() playSound(IDS.Sons.Descarregando) end)
            task.wait(1)
        end
        
        TimerLbl:Destroy()
        resetPlayerPhysics()
        ScreenGui:Destroy()
        
        local char = lplayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local randomDirection = Vector3.new(
                math.random(-100, 100),
                math.random(10, 100), 
                math.random(-100, 100)
            ).Unit
            
            local att = Instance.new("Attachment", hrp)
            
            local linVel = Instance.new("LinearVelocity")
            linVel.Attachment0 = att
            linVel.MaxForce = 999999
            linVel.VectorVelocity = randomDirection * 350
            linVel.Parent = hrp
            
            local rotVel = Instance.new("AngularVelocity")
            rotVel.Attachment0 = att
            rotVel.MaxTorque = 999999
            rotVel.AngularVelocity = Vector3.new(math.random(-20,20), math.random(-20,20), math.random(-20,20))
            rotVel.Parent = hrp
            
            task.spawn(function()
                task.wait(3.5)
                linVel:Destroy()
                rotVel:Destroy()
                att:Destroy()
            end)
        end
    end
end

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.Up then
        verificarCombos("A")
    elseif input.KeyCode == Enum.KeyCode.Down then
        verificarCombos("B")
    elseif input.KeyCode == Enum.KeyCode.Left then
        verificarCombos("C")
    elseif input.KeyCode == Enum.KeyCode.Right then
        verificarCombos("D")
    end
end)
