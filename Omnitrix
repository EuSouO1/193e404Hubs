local function shoutInChat(text)
    if not gritoAtivo then return end
    
    local msg = string.upper(text) .. "!"
    if game:GetService("TextChatService").TextChannels:FindFirstChild("RBXGeneral") then
        game:GetService("TextChatService").TextChannels.RBXGeneral:SendAsync(msg)
    else
        pcall(function()
            game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
                :FindFirstChild("SayMessageRequest"):FireServer(msg, "All")
        end)
    end
end

