-- === SISTEMA DE ARRASTAR O PAINEL (DRAGGABLE) ===
local dragging, dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    MainPanel.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

MainPanel.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainPanel.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

MainPanel.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)


-- === SISTEMA DE CHAT (GRITO) ===
local function shoutInChat(text)
    local msg = string.upper(text) .. "!"
    if game:GetService("TextChatService").TextChannels:FindFirstChild("RBXGeneral") then
        game:GetService("TextChatService").TextChannels.RBXGeneral:SendAsync(msg)
    else
        pcall(function()
            game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
                :FindFirstChild("SayMessageRequest"):FireServer(msg, "All")
        end)
    end
end

-- === RESTAURAR FÍSICA AO NORMAL ===
local function resetPlayerPhysics()
    for _, loop in pairs(activeLoops) do pcall(function() loop:Disconnect() end) end
    activeLoops = {}
    
    workspace.Gravity = originalGravity
    local char = lplayer.Character
    if char and char:FindFirstChildOfClass("Humanoid") then
        local hum = char:FindFirstChildOfClass("Humanoid")
        hum.WalkSpeed = 16
        hum.JumpPower = 50
        hum.UseJumpPower = true
    end
    
    if ScreenGui:FindFirstChild("BestaVision") then ScreenGui.BestaVision:Destroy() end
    if ScreenGui:FindFirstChild("CalcFrame") then ScreenGui.CalcFrame:Destroy() end
    if char and char:FindFirstChild("OriginalSize") then
        char.OriginalSize:Destroy()
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then pcall(function() v.Size = v.Size / 2 end) end
        end
    end
    for _, p in pairs(workspace:GetDescendants()) do
        if p:IsA("Highlight") and p.Name == "BestaESP" then p:Destroy() end
    end
end

-- === PULO INFINITO ===
local function enableInfiniteJump(speed, jPower)
    local char = lplayer.Character
    local hum = char:FindFirstChildOfClass("Humanoid")
    local jumpConn = UserInputService.JumpRequest:Connect(function()
        if char and hum and char:FindFirstChild("HumanoidRootPart") then
            hum.WalkSpeed = speed
            hum.JumpPower = jPower
            char.HumanoidRootPart.Velocity = Vector3.new(char.HumanoidRootPart.Velocity.X, jPower * 1.5, char.HumanoidRootPart.Velocity.Z)
        end
    end)
    table.insert(activeLoops, jumpConn)
end

-- === APLICAR PODERES DOS ALIENS ===
local function applyAlienPowers(alienName)
    resetPlayerPhysics()
    local char = lplayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    if alienName == "Chama" then
        hum.WalkSpeed = 20
        hum.JumpPower = 75
        workspace.Gravity = originalGravity * 3
        
    elseif alienName == "Quatro Braços" then
        hum.WalkSpeed = 32
        hum.JumpPower = 100
        local tag = Instance.new("BoolValue", char) tag.Name = "OriginalSize"
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then pcall(function() v.Size = v.Size * 2 end) end
        end
        
    elseif alienName == "XLR8" then
        hum.WalkSpeed = 50
        hum.JumpPower = 50
        local xlr8Loop = RunService.Heartbeat:Connect(function()
            if hum.MoveDirection.Magnitude > 0 then
                if hum.WalkSpeed < 500 then hum.WalkSpeed = hum.WalkSpeed + 2 end
            else
                if hum.WalkSpeed > 50 then
                    hum.WalkSpeed = 1
                    if char:FindFirstChild("HumanoidRootPart") then char.HumanoidRootPart.Velocity = Vector3.new(0,0,0) end
                    task.wait(0.1)
                    hum.WalkSpeed = 50
                end
            end
        end)
        table.insert(activeLoops, xlr8Loop)
        
    elseif alienName == "Bala de Canhão" then
        hum.WalkSpeed = 10
        hum.JumpPower = 60
        local BallToggle = Instance.new("TextButton", ScreenGui)
        BallToggle.Size = UDim2.new(0, 120, 0, 40)
        BallToggle.Position = UDim2.new(0.85, 0, 0.35, 0)
        BallToggle.Text = "Modo Bola: OFF"
        BallToggle.BackgroundColor3 = Color3.fromRGB(85, 170, 0)
        BallToggle.ZIndex = 6
        local modeOn = false
        BallToggle.MouseButton1Click:Connect(function()
            modeOn = not modeOn
            if modeOn then
                BallToggle.Text = "Modo Bola: ON"
                hum.WalkSpeed = 60; hum.JumpPower = 0
            else
                BallToggle.Text = "Modo Bola: OFF"
                hum.WalkSpeed = 10; hum.JumpPower = 60
            end
        end)
        table.insert(activeLoops, {Disconnect = function() BallToggle:Destroy() end})

    elseif alienName == "Ultra T" then
        hum.WalkSpeed = 20
        hum.JumpPower = 60
        workspace.Gravity = originalGravity / 6
        
    elseif alienName == "Diamante" then
        hum.WalkSpeed = 25
        hum.JumpPower = 70
        
    elseif alienName == "Fantasmatico" then
        hum.WalkSpeed = 26
        hum.JumpPower = 60
        workspace.Gravity = originalGravity / 2
        enableInfiniteJump(50, 10)
        
    elseif alienName == "Insectoide" then
        hum.WalkSpeed = 20
        hum.JumpPower = 75
        workspace.Gravity = originalGravity / 2.5
        enableInfiniteJump(75, 20)
        
    elseif alienName == "Massa Cinzenta" then
        hum.WalkSpeed = 12
        hum.JumpPower = 55
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then pcall(function() v.Size = v.Size / 4 end) end
        end
        local CalcFrame = Instance.new("Frame", ScreenGui)
        CalcFrame.Size = UDim2.new(0, 150, 0, 150)
        CalcFrame.Position = UDim2.new(0.1, 0, 0.4, 0)
        CalcFrame.BackgroundColor3 = Color3.new(0.2, 0.2, 0.2)
        CalcFrame.ZIndex = 6
        local CalcTxt = Instance.new("TextLabel", CalcFrame)
        CalcTxt.Size = UDim2.new(1, 0, 0.3, 0); CalcTxt.Text = "Massa Cinzenta Inteligência"; CalcTxt.TextColor3 = Color3.new(1,1,1); CalcTxt.TextScaled = true; CalcTxt.ZIndex = 7
        local CalcBtn = Instance.new("TextButton", CalcFrame)
        CalcBtn.Size = UDim2.new(0.8, 0, 0.5, 0); CalcBtn.Position = UDim2.new(0.1, 0, 0.4, 0); CalcBtn.Text = "Calcular"; CalcBtn.ZIndex = 7
        CalcBtn.MouseButton1Click:Connect(function() CalcTxt.Text = "Resultado: " .. tostring(math.random(1000, 99999)) end)
        table.insert(activeLoops, {Disconnect = function() CalcFrame:Destroy() end})
        
    elseif alienName == "Besta" then
        hum.WalkSpeed = 40
        hum.JumpPower = 65
        local BestaVision = Instance.new("Frame", ScreenGui)
        BestaVision.Size = UDim2.new(1, 0, 1, 0); BestaVision.BackgroundColor3 = Color3.new(0,0,0); BestaVision.ZIndex = 1
        local visionLoop = task.spawn(function()
            while true do
                task.wait(math.random(5, 10))
                BestaVision.BackgroundTransparency = 0.8
                task.wait(0.3)
                BestaVision.BackgroundTransparency = 0
            end
        end)
        table.insert(activeLoops, {Disconnect = function() task.cancel(visionLoop); BestaVision:Destroy() end})
        local espLoop = RunService.Heartbeat:Connect(function()
            if not char:FindFirstChild("HumanoidRootPart") then return end
            for _, p in pairs(workspace:GetDescendants()) do
                if p:IsA("Humanoid") and p.Parent ~= char and p.Parent:FindFirstChild("HumanoidRootPart") then
                    local targetHRP = p.Parent.HumanoidRootPart
                    local dist = (char.HumanoidRootPart.Position - targetHRP.Position).Magnitude
                    if dist <= 100 then
                        if not p.Parent:FindFirstChild("BestaESP") then
                            local hl = Instance.new("Highlight", p.Parent)
                            hl.Name = "BestaESP"; hl.FillColor = Color3.new(1, 0, 0); hl.OutlineColor = Color3.new(1, 0, 0)
                        end
                    else
                        if p.Parent:FindFirstChild("BestaESP") then p.Parent.BestaESP:Destroy() end
                    end
                end
            end
        end)
        table.insert(activeLoops, espLoop)
        
    elseif alienName == "Aquatico" then
        hum.WalkSpeed = 15
        hum.JumpPower = 55
        local timerForaDaAgua = 0
        local aquaticoLoop = RunService.Heartbeat:Connect(function()
            if not char:FindFirstChild("HumanoidRootPart") then return end
            local naAgua = false
            local parts = workspace:GetPartsInPart(char.HumanoidRootPart)
            for _, part in pairs(parts) do
                if part.Color.B > 0.6 and part.Color.G < 0.5 and part.Color.R < 0.5 then
                    naAgua = true
                    break
                end
            end
            if naAgua then
                hum.WalkSpeed = 75; hum.JumpPower = 55; timerForaDaAgua = 0
            else
                timerForaDaAgua = timerForaDaAgua + task.wait()
                if timerForaDaAgua >= 120 then
                    hum.WalkSpeed = 0; hum.JumpPower = 0
                else
                    hum.WalkSpeed = math.max(0, 15 - (timerForaDaAgua * 0.12))
                end
            end
        end)
        table.insert(activeLoops, aquaticoLoop)
    end
end

-- === LÓGICA DE TRANSFORMAÇÃO ===
local function transform(alienName)
    if omnitrixCooldown then return end
    isTransformed = true
    currentAlienActive = alienName
    SelectionPanel.Visible = false
    OmnitrixBtn.Visible = true
    
    playSound(IDS.Sons.Transformar)
    shoutInChat(alienName)
    applyAlienPowers(alienName)
    
    local timeActive = math.random(120, 360)
    task.wait(timeActive - 5)
    
    playSound(IDS.Sons.Descarregando)
    task.wait(5)
    
    isTransformed = false
    currentAlienActive = ""
    resetPlayerPhysics()
    
    omnitrixCooldown = true
    OmnitrixBtn.ImageColor3 = Color3.new(1, 0, 0)
    task.wait(480)
    
    omnitrixCooldown = false
    OmnitrixBtn.ImageColor3 = Color3.new(1, 1, 1)
    playSound(IDS.Sons.Recarregar)
end

-- === MENU DE SELEÇÃO / SPAM DETECT ===
local function updateSilhouette()
    SilhouetteImg.Image = IDS.Silhuetas[currentAlienIndex].ID
end

OmnitrixBtn.MouseButton1Click:Connect(function()
    if omnitrixCooldown or isTransformed then return end
    
    local now = os.clock()
    if now - lastClickTime < 0.4 then
        clickCount = clickCount + 1
    else
        clickCount = 1
    end
    lastClickTime = now
    
    if clickCount >= 4 then
        local randomAlien = IDS.Silhuetas[math.random(1, #IDS.Silhuetas)].Nome
        transform(randomAlien)
        clickCount = 0
        return
    end
    
    isOmnitrixOn = not isOmnitrixOn
    if isOmnitrixOn then
        playSound(IDS.Sons.Ligando)
        SelectionPanel.Visible = true
        OmnitrixBtn.Visible = false
        updateSilhouette()
    else
        SelectionPanel.Visible = false
        OmnitrixBtn.Visible = true
    end
end)

NextBtn.MouseButton1Click:Connect(function()
    if not isOmnitrixOn then return end
    playSound(IDS.Sons.Trocar)
    currentAlienIndex = currentAlienIndex + 1
    if currentAlienIndex > #IDS.Silhuetas then currentAlienIndex = 1 end
    updateSilhouette()
end)

PrevBtn.MouseButton1Click:Connect(function()
    if not isOmnitrixOn then return end
    playSound(IDS.Sons.Trocar)
    currentAlienIndex = currentAlienIndex - 1
    if currentAlienIndex < 1 then currentAlienIndex = #IDS.Silhuetas end
    updateSilhouette()
end)

SilhouetteImg.MouseButton1Click:Connect(function()
    if not isOmnitrixOn or isTransformed then return end
    local chosenAlien = IDS.Silhuetas[currentAlienIndex].Nome
    transform(chosenAlien)
end)

