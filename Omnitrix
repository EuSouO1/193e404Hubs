	if not char then return end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	local targetSpeed = 16
	local targetJump = 50
	local isCustomSpeedLoop = false

	if alienName == "Chama" then
		targetSpeed = 20
		targetJump = 25  
		workspace.Gravity = originalGravity / 3

	elseif alienName == "Quatro Braços" then
		targetSpeed = 40  
		targetJump = 150  

	elseif alienName == "XLR8" then
		isCustomSpeedLoop = true
		targetJump = 50
		hum.WalkSpeed = 50

		local waterFloat = Instance.new("BodyVelocity")
