        Instance.new("UICorner", Display).CornerRadius = UDim.new(0, 4)
        
        local ButtonContainer = Instance.new("Frame", CalcFrame)
        ButtonContainer.Size = UDim2.new(0, 200, 0, 200)
        ButtonContainer.Position = UDim2.new(0, 10, 0, 60)
        ButtonContainer.BackgroundTransparency = 1
        ButtonContainer.ZIndex = 7

        local UIGridLayout = Instance.new("UIGridLayout", ButtonContainer)
        UIGridLayout.CellSize = UDim2.new(0, 45, 0, 42)
        UIGridLayout.CellPadding = UDim2.new(0, 6, 0, 6)
        
        local botoes = {
            "7", "8", "9", "/",
            "4", "5", "6", "*",
            "1", "2", "3", "-",
            "C", "0", "=", "+"
        }
        
        local expressao = ""
        
        for _, caractere in ipairs(botoes) do
            local Btn = Instance.new("TextButton", ButtonContainer)
            Btn.Text = caractere
            Btn.TextSize = 20
            Btn.TextColor3 = Color3.new(1, 1, 1)
            Btn.ZIndex = 8
            
            if caractere == "C" then
                Btn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
            elseif caractere == "=" then
                Btn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
            elseif tonumber(caractere) then
                Btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            else
                Btn.BackgroundColor3 = Color3.fromRGB(90, 90, 90)
            end
            
            Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 4)
            
            Btn.MouseButton1Click:Connect(function()
                if caractere == "C" then
                    expressao = ""
                    Display.Text = "0"
                elseif caractere == "=" then
                    if expressao ~= "" then
                        local resultado = calcularSeguro(expressao)
                        Display.Text = tostring(resultado)
                        expressao = (resultado == "Erro") and "" or tostring(resultado)
                    end
                else
                    if Display.Text == "0" or Display.Text == "Erro" then
                        if tonumber(caractere) then expressao = "" end
                    end
                    expressao = expressao .. caractere
                    Display.Text = expressao
                end
            end)
        end
        
        table.insert(activeLoops, {Disconnect = function() CalcFrame:Destroy() end})
        
    elseif alienName == "Besta" then
        isCustomSpeedLoop = true
        targetSpeed = 40
        targetJump = 65
        
        local CC = Instance.new("ColorCorrectionEffect")
        CC.Name = "BestaColorCorrection"
        CC.Brightness = -0.7   
        CC.Contrast = 0.4      
        CC.Saturation = -0.8   
        CC.TintColor = Color3.fromRGB(30, 20, 10) 
        CC.Parent = Lighting
        
        local bestaLoop = RunService.Heartbeat:Connect(function()
            if hum and hum.Parent then
                if hum.WalkSpeed ~= targetSpeed then hum.WalkSpeed = targetSpeed end
                if hum.JumpPower ~= targetJump then hum.JumpPower = targetJump end
                if not hum.UseJumpPower then hum.UseJumpPower = true end
            end
            
            if CC and CC.Parent == Lighting then
                if CC.Brightness ~= -0.7 and CC.Brightness ~= -0.4 then
                    CC.Brightness = -0.7
                end
            elseif not Lighting:FindFirstChild("BestaColorCorrection") and isTransformed and currentAlienActive == "Besta" then
                CC = Instance.new("ColorCorrectionEffect")
                CC.Name = "BestaColorCorrection"
                CC.Brightness = -0.7   
                CC.Contrast = 0.4      
                CC.Saturation = -0.8   
                CC.TintColor = Color3.fromRGB(30, 20, 10) 
                CC.Parent = Lighting
            end
        end)
        table.insert(activeLoops, bestaLoop)
        
        local bestaVisionActive = true
        local visionLoop = task.spawn(function()
            while bestaVisionActive do
                task.wait(math.random(4, 8))
                if not bestaVisionActive or not CC then break end
                CC.Brightness = -0.4 
                task.wait(0.2)
                if not bestaVisionActive or not CC then break end
                CC.Brightness = -0.7 
            end
        end)
        
        table.insert(activeLoops, {Disconnect = function() 
            bestaVisionActive = false 
            task.cancel(visionLoop) 
            if CC then CC:Destroy() end 
        end})
        
        local bestaESPLoopActive = true
        local bestaESPThread = task.spawn(function()
            while bestaESPLoopActive do
                if char and char:FindFirstChild("HumanoidRootPart") then
                    for _, p in pairs(workspace:GetDescendants()) do
                        if p:IsA("Humanoid") and p.Parent ~= char and p.Parent:FindFirstChild("HumanoidRootPart") then
                            local targetHRP = p.Parent.HumanoidRootPart
                            local dist = (char.HumanoidRootPart.Position - targetHRP.Position).Magnitude
                            if dist <= 100 then
                                if not p.Parent:FindFirstChild("BestaESP") then
                                    local hl = Instance.new("Highlight", p.Parent)
                                    hl.Name = "BestaESP"
                                    hl.FillColor = Color3.new(1, 0, 0)
                                    hl.OutlineColor = Color3.new(1, 0, 0)
                                    hl.FillTransparency = 0.2
                                end
                            else
                                if p.Parent:FindFirstChild("BestaESP") then p.Parent.BestaESP:Destroy() end
                            end
                        end
                    end
                end
                task.wait(1) 
            end
        end)
        table.insert(activeLoops, {Disconnect = function() bestaESPLoopActive = false; task.cancel(bestaESPThread) end})
        
    elseif alienName == "Aquatico" then
        isCustomSpeedLoop = true
        targetJump = 55
        local timerForaDaAgua = 0
        
        local overlapParams = OverlapParams.new()
        overlapParams.FilterType = Enum.RaycastFilterType.Exclude
        overlapParams.FilterDescendantsInstances = {char}
        
        local azulPuro = Color3.fromRGB(0, 0, 255)
        local cianoPuro = Color3.fromRGB(0, 255, 255)
        local nomesAgua = {"water", "ocean", "sea", "agua", "rio", "lake"}
        
        local aquaticoLoop = RunService.Heartbeat:Connect(function()
            if not char:FindFirstChild("HumanoidRootPart") then return end
            local hrp = char.HumanoidRootPart
            local naAgua = false
            
            if game.PlaceId == 4924922222 then
                local alturaY = hrp.Position.Y
                if alturaY >= -6 and alturaY <= -3 then
                    naAgua = true
                end
            end
            
            if not naAgua then
                local parts = workspace:GetPartsInPart(hrp, overlapParams)
                for _, part in pairs(parts) do
                    if part.Parent:FindFirstChildOfClass("Humanoid") or (part.Parent.Parent and part.Parent.Parent:FindFirstChildOfClass("Humanoid")) then
                        continue
                    end
                    
                    local nomeMinusculo = string.lower(part.Name)
                    local achouNome = false
                    for _, palavra in ipairs(nomesAgua) do
                        if string.find(nomeMinusculo, palavra) then
                            achouNome = true
                            break
                        end
                    end
                    
                    if achouNome then
                        naAgua = true
                        break
                    end
                    
                    local r, g, b = part.Color.R, part.Color.G, part.Color.B
                    local distAzul = math.sqrt((r - azulPuro.R)^2 + (g - azulPuro.G)^2 + (b - azulPuro.B)^2)
                    local distCiano = math.sqrt((r - cianoPuro.R)^2 + (g - cianoPuro.G)^2 + (b - cianoPuro.B)^2)
                    
                    if (distAzul < 0.85 or distCiano < 0.85) and (b > r or g > r) then
                        naAgua = true
                        break
                    end
                end
            end
            
            if naAgua then
                hum.WalkSpeed = 100
                hum.JumpPower = 110
                timerForaDaAgua = 0 
                targetJump = 110
            else
                timerForaDaAgua = timerForaDaAgua + task.wait()
                targetJump = 55
                
                if timerForaDaAgua >= 120 then
                    hum.WalkSpeed = 0
                    hum.JumpPower = 0
                    targetJump = 0
                else
                    hum.WalkSpeed = math.max(0, 15 - (timerForaDaAgua * 0.12))
                end
            end
            
            if hum.JumpPower ~= targetJump and timerForaDaAgua < 120 then 
                hum.JumpPower = targetJump 
            end
        end)
        table.insert(activeLoops, aquaticoLoop)
    end
    
    if not isCustomSpeedLoop then
        local attributeProtector = RunService.Heartbeat:Connect(function()
            if hum and hum.Parent then
                if hum.WalkSpeed ~= targetSpeed then
                    hum.WalkSpeed = targetSpeed
                end
                if hum.JumpPower ~= targetJump then
                    hum.JumpPower = targetJump
                end
                if hum.UseJumpPower == false then
                    hum.UseJumpPower = true
                end
            end
        end)
        table.insert(activeLoops, attributeProtector)
    end
end

-- === LÓGICA DE TRANSFORMAÇÃO ===
local function transform(alienName)
    if omnitrixCooldown or isTransformed then return end
    
    isTransformed = true
    currentAlienActive = alienName
    SelectionPanel.Visible = false
    OmnitrixBtn.Visible = true
    
    MainPanel.BackgroundColor3 = CORES_PAINEL.Transformado
    
    pcall(function() playSound(IDS.Sons.Transformar) end)
    
    if alienName == "Besta" then
        shoutInChat("RAAAHHHHHHHHHHHHHHHHHHH")
    else
        shoutInChat(alienName)
    end
    
    applyAlienPowers(alienName)
    
    task.spawn(function()
        local timeActive = math.random(120, 360)
        local tempoEsperaPrincipal = timeActive - 5
        local tempoPassado = 0
        
        while tempoPassado < tempoEsperaPrincipal and isTransformed and currentAlienActive == alienName do
            task.wait(1)
            tempoPassado = tempoPassado + 1
        end
        
        if isTransformed and currentAlienActive == alienName then
            pcall(function() playSound(IDS.Sons.Descarregando) end)
            
            for i = 1, 20 do
                if not isTransformed or currentAlienActive ~= alienName then break end
                if MainPanel.BackgroundColor3 == CORES_PAINEL.Transformado or MainPanel.BackgroundColor3 == CORES_PAINEL.Carregado then
                    MainPanel.BackgroundColor3 = CORES_PAINEL.Descarregaged
                else
                    MainPanel.BackgroundColor3 = CORES_PAINEL.Carregado
                end
                task.wait(0.25)
            end
            
            if isTransformed and currentAlienActive == alienName then
                isTransformed = false
                currentAlienActive = ""
                
                resetPlayerPhysics()
                omnitrixCooldown = true
                MainPanel.BackgroundColor3 = CORES_PAINEL.Descarregaged
                
                task.wait(480)
                
                omnitrixCooldown = false
                MainPanel.BackgroundColor3 = CORES_PAINEL.Carregado
                pcall(function() playSound(IDS.Sons.Recarregar) end)
            end
        end
    end)
end

-- === MENU DE SELEÇÃO ===
local function updateSilhouette()
    SilhouetteImg.Text = IDS.Silhuetas[currentAlienIndex].Emoji
end

OmnitrixBtn.MouseButton1Click:Connect(function()
    if omnitrixCooldown or isTransformed or ConfigsMenu.Visible then return end
    
    local now = os.clock()
    if now - lastClickTime < 0.4 then
        clickCount = clickCount + 1
    else
        clickCount = 1
    end
    lastClickTime = now
    
    if clickCount >= 4 then
        local randomAlien = IDS.Silhuetas[math.random(1, #IDS.Silhuetas)].Nome
        transform(randomAlien)
        clickCount = 0
        return
    end
    
    isOmnitrixOn = not isOmnitrixOn
    if isOmnitrixOn then
        pcall(function() playSound(IDS.Sons.Ligando) end)
        SelectionPanel.Visible = true
        OmnitrixBtn.Visible = false
        updateSilhouette()
    else
        SelectionPanel.Visible = false
        OmnitrixBtn.Visible = true
    end
end)

NextBtn.MouseButton1Click:Connect(function()
    if not isOmnitrixOn or ConfigsMenu.Visible then return end
    pcall(function() playSound(IDS.Sons.Trocar) end)
    currentAlienIndex = currentAlienIndex + 1
    if currentAlienIndex > #IDS.Silhuetas then currentAlienIndex = 1 end
    updateSilhouette()
end)

PrevBtn.MouseButton1Click:Connect(function()
    if not isOmnitrixOn or ConfigsMenu.Visible then return end
    pcall(function() playSound(IDS.Sons.Trocar) end)
    currentAlienIndex = currentAlienIndex - 1
    if currentAlienIndex < 1 then currentAlienIndex = #IDS.Silhuetas end
    updateSilhouette()
end)

SilhouetteImg.MouseButton1Click:Connect(function()
    if not isOmnitrixOn or isTransformed or ConfigsMenu.Visible then return end
    local chosenAlien = IDS.Silhuetas[currentAlienIndex].Nome
    transform(chosenAlien)
end)

