-- === CICLO DE TRANSFORMAÇÃO E COOLDOWN ===
local function startOmnitrixCooldown()
    isTransformed = false
    currentAlienActive = ""
    resetPlayerPhysics()
    
    OmnitrixBtn.Text = IDS.OmnitrixEmoji
    OmnitrixBtn.TextSize = 75
    SelectionPanel.Visible = false
    OmnitrixBtn.Visible = true
    omnitrixCooldown = true
    
    MainPanel.BackgroundColor3 = CORES_PAINEL.Descarregaged
    
    task.wait(10) -- Tempo descarregado
    
    pcall(function() playSound(IDS.Sons.Recarregar) end)
    MainPanel.BackgroundColor3 = CORES_PAINEL.Carregado
    omnitrixCooldown = false
end

local function transformIntoAlien(alienName)
    if omnitrixCooldown then return end
    isTransformed = true
    currentAlienActive = alienName
    
    SelectionPanel.Visible = false
    OmnitrixBtn.Visible = false 
    
    MainPanel.BackgroundColor3 = CORES_PAINEL.Transformado
    
    shoutInChat(alienName)
    pcall(function() playSound(IDS.Sons.Transformar) end)
    
    applyAlienPowers(alienName)
    
    if masterControlActive then
        SelectionPanel.Visible = true
        SilhouetteImg.Text = ListaAliensDisponiveis[currentAlienIndex].Emoji
        return 
    end
    
    task.wait(30) -- Tempo de transformação ativa antes de descarregar
    
    if currentAlienActive == alienName and isTransformed and not masterControlActive then
        startOmnitrixCooldown()
    end
end

-- === INTERAÇÃO DO BOTÃO PRINCIPAL (OMNITRIX) ===
OmnitrixBtn.MouseButton1Click:Connect(function()
    if omnitrixCooldown or ConfigsMenu.Visible then return end
    
    local now = os.clock()
    if now - lastClickTime < 0.4 then
        clickCount = clickCount + 1
    else
        clickCount = 1
    end
    lastClickTime = now
    
    if clickCount >= 5 then
        clickCount = 0
        if not isOmnitrixOn and not isTransformed then
            isTransformingQueue = true
            transformClicksDuringDelay = 0
            
            pcall(function() playSound(IDS.Sons.Ligando) end)
            MainPanel.BackgroundColor3 = CORES_PAINEL.DnaDetec
            OmnitrixBtn.Text = "⚡"
            OmnitrixBtn.TextSize = 65
            
            local trackingLoop = UserInputService.InputBegan:Connect(function(input, gpe)
                if not gpe and input.UserInputType == Enum.UserInputType.MouseButton1 then
                    transformClicksDuringDelay = transformClicksDuringDelay + 1
                end
            end)
            
            task.wait(3.5)
            trackingLoop:Disconnect()
            isTransformingQueue = false
            
            if transformClicksDuringDelay >= 7 then
                local sorteado = ListaAliensDisponiveis[math.random(1, #ListaAliensDisponiveis)].Nome
                transformIntoAlien(sorteado)
            else
                MainPanel.BackgroundColor3 = CORES_PAINEL.Carregado
                OmnitrixBtn.Text = IDS.OmnitrixEmoji
                OmnitrixBtn.TextSize = 75
            end
            return
        end
    end
    
    if isTransformed then
        if masterControlActive then
            startOmnitrixCooldown()
        else
            pcall(function() playSound(IDS.Sons.Descarregando) end)
            startOmnitrixCooldown()
        end
        return
    end
    
    isOmnitrixOn = not isOmnitrixOn
    if isOmnitrixOn then
        pcall(function() playSound(IDS.Sons.Ligando) end)
        OmnitrixBtn.Visible = false
        SelectionPanel.Visible = true
        SilhouetteImg.Text = ListaAliensDisponiveis[currentAlienIndex].Emoji
    else
        OmnitrixBtn.Visible = true
        SelectionPanel.Visible = false
    end
end)

