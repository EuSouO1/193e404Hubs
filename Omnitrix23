-- === RESTAURAR FÍSICA AO NORMAL ===
local function resetPlayerPhysics()
	for _, loop in pairs(activeLoops) do pcall(function() loop:Disconnect() end) end
	activeLoops = {}

	workspace.Gravity = originalGravity
	local char = lplayer.Character
	if char then
		local hrp = char:FindFirstChild("HumanoidRootPart")
		local hum = char:FindFirstChildOfClass("Humanoid")

		if hrp then
			if hrp:FindFirstChild("InvisAntiVoid") then
				hrp.InvisAntiVoid:Destroy()

				-- CONSERTO: Força ficar 100% em pé antes de subir para a superfície
				local _, camY, _ = hrp.CFrame:ToOrientation()
				hrp.CFrame = CFrame.new(hrp.Position.X, hrp.Position.Y + 22, hrp.Position.Z) * CFrame.fromOrientation(0, camY, 0)
			else
				-- CONSERTO: Se descarregar sem estar invisível, também garante que endireita na hora
				local _, camY, _ = hrp.CFrame:ToOrientation()
				hrp.CFrame = CFrame.new(hrp.Position) * CFrame.fromOrientation(0, camY, 0)
			end

			if hrp:FindFirstChild("FantasmaticoGyro") then
				hrp.FantasmaticoGyro:Destroy()
			end
		end

		if hum then
			hum.WalkSpeed = 16
			hum.JumpPower = 50
			hum.UseJumpPower = true
			hum.CameraOffset = Vector3.new(0, 0, 0)
		end

		for _, part in pairs(char:GetChildren()) do
			if part:IsA("BasePart") then part.CanCollide = true end
		end
	end

	workspace.CurrentCamera.CameraSubject = char and char:FindFirstChildOfClass("Humanoid") or nil

	if Lighting:FindFirstChild("BestaColorCorrection") then 
		Lighting.BestaColorCorrection:Destroy() 
	end

	if ScreenGui:FindFirstChild("RealCalcFrame") then ScreenGui.RealCalcFrame:Destroy() end

	for _, p in pairs(workspace:GetDescendants()) do
		if p:IsA("Highlight") and p.Name == "BestaESP" then p:Destroy() end
	end
end

-- === PULO INFINITO E VOO ULTRA RÁPIDO ===
local function enableInfiniteJump(baseSpeed, jPower)
	local char = lplayer.Character
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	local flySpeed = baseSpeed * 5

	local jumpConn = UserInputService.JumpRequest:Connect(function()
		if char and hum and char:FindFirstChild("HumanoidRootPart") then
			char.HumanoidRootPart.Velocity = Vector3.new(char.HumanoidRootPart.Velocity.X, jPower * 1.5, char.HumanoidRootPart.Velocity.Z)
			hum.WalkSpeed = flySpeed
		end
	end)
	table.insert(activeLoops, jumpConn)

	local landCheck = RunService.Heartbeat:Connect(function()
		if hum.FloorMaterial ~= Enum.Material.Air then
			if hum.WalkSpeed ~= baseSpeed then
				hum.WalkSpeed = baseSpeed
			end
		else
			if hum.WalkSpeed ~= flySpeed and hum.WalkSpeed ~= 100 then 
				hum.WalkSpeed = flySpeed
			end
		end
	end)
	table.insert(activeLoops, landCheck)
end

-- === FUNÇÃO AUXILIAR MATEMÁTICA PARA O MASSA CINZENTA ===
local function calcularSeguro(exp)
	local n1, op, n2 = string.match(exp, "^([%d%.]+)([%+%-%*/])([%d%.]+)$")
	if not n1 or not op or not n2 then return "Erro" end
	local num1, num2 = tonumber(n1), tonumber(n2)
	if op == "+" then return num1 + num2
	elseif op == "-" then return num1 - num2
	elseif op == "*" then return num1 * num2
	elseif op == "/" then return num2 == 0 and "Erro" or num1 / num2 end
	return "Erro"
end

-- === APLICAR PODERES DOS ALIENS ===
local function applyAlienPowers(alienName)
	resetPlayerPhysics()
	local char = lplayer.Character
	if not char then return end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	local targetSpeed = 16
	local targetJump = 50
	local isCustomSpeedLoop = false

	if alienName == "Homem-Carvão" then
		targetSpeed = 20
		targetJump = 50
		enableInfiniteJump(targetSpeed, 25)
		workspace.Gravity = originalGravity / 6

	elseif alienName == "Humanual" then
		targetSpeed = 40  
		targetJump = 150  

	elseif alienName == "Apressado" then
		isCustomSpeedLoop = true
		targetJump = 50
		hum.WalkSpeed = 50

		local hrp = char:FindFirstChild("HumanoidRootPart")
		local overlapParams = OverlapParams.new()
		overlapParams.FilterType = Enum.RaycastFilterType.Exclude
		overlapParams.FilterDescendantsInstances = {char}

		local azulPuro, cianoPuro = Color3.fromRGB(0, 0, 255), Color3.fromRGB(0, 255, 255)
		local nomesAgua = {"water", "ocean", "sea", "agua", "rio", "lake"}

		local waterFloat = nil 
		local partesSolidificadas = {} -- Tabela para rastrear o que alteramos

		local xxlr8Loop = RunService.Heartbeat:Connect(function()
			if not char or not char:FindFirstChild("HumanoidRootPart") then return end
			hrp = char.HumanoidRootPart

			-- 1. LÓGICA DE VELOCIDADE
			if hum.MoveDirection.Magnitude > 0 then
				if hum.WalkSpeed < 500 then hum.WalkSpeed = hum.WalkSpeed + 2 end
			else
				if hum.WalkSpeed > 50 then
					hum.WalkSpeed = 1
					hrp.Velocity = Vector3.new(0,0,0)
					task.wait(0.1)
					hum.WalkSpeed = 50
				end
			end

			-- 2. DETECÇÃO DE ÁGUA E LIMPEZA
			local estaRapido = hum.WalkSpeed >= 150
			local partesAoRedor = workspace:GetPartsInPart(hrp, overlapParams)
			local tocandoAgua = false
			local listaPartesAtuais = {}

			for _, part in pairs(partesAoRedor) do
				local n = string.lower(part.Name)
				local ehAgua = false

				for _, p in ipairs(nomesAgua) do if string.find(n, p) then ehAgua = true break end end
				if not ehAgua then
					local r, g, b = part.Color.R, part.Color.G, part.Color.B
					local distAzul = math.sqrt((r-azulPuro.R)^2 + (g-azulPuro.G)^2 + (b-azulPuro.B)^2)
					local distCiano = math.sqrt((r-cianoPuro.R)^2 + (g-cianoPuro.G)^2 + (b-cianoPuro.B)^2)
					if (distAzul < 0.85 or distCiano < 0.85) and (b > r or g > r) then ehAgua = true end
				end

				if ehAgua then
					tocandoAgua = true
					listaPartesAtuais[part] = true

					-- Se estiver rápido, solidifica
					if estaRapido then
						part.CanCollide = true
						partesSolidificadas[part] = true
					end
				end
			end

			-- Limpeza: Se a parte estava sólida mas não estamos mais tocando ou rápido, desfaz
			for part, _ in pairs(partesSolidificadas) do
				if not listaPartesAtuais[part] or not estaRapido then
					part.CanCollide = false
					partesSolidificadas[part] = nil
				end
			end

			-- 3. GESTÃO DO IMPULSO
			local estaNaAlturaCerta = (game.PlaceId == 4924922222 and hrp.Position.Y < -0.05)

			if tocandoAgua and estaRapido and estaNaAlturaCerta then
				if not waterFloat then
					waterFloat = Instance.new("BodyVelocity")
					waterFloat.Name = "XLR8WaterImpulse"
					waterFloat.MaxForce = Vector3.new(0, 50000, 0)
					waterFloat.Velocity = Vector3.new(0, 25, 0)
					waterFloat.Parent = hrp
				end
			else
				if waterFloat then
					waterFloat:Destroy()
					waterFloat = nil
				end
			end
		end)

		table.insert(activeLoops, xxlr8Loop)
		table.insert(activeLoops, {Disconnect = function() 
			if waterFloat then waterFloat:Destroy() end
			for part, _ in pairs(partesSolidificadas) do
				if part then part.CanCollide = false end
			end
		end})

	elseif alienName == "Rolador" then
		targetSpeed = 10
		targetJump = 60

		local BallToggle = Instance.new("TextButton", ScreenGui)
		BallToggle.Size = UDim2.new(0, 140, 0, 40)
		BallToggle.Position = UDim2.new(0.85, -20, 0.35, 0)
		BallToggle.Text = "Modo Bola: OFF"
		BallToggle.BackgroundColor3 = Color3.fromRGB(222, 222, 23)
		BallToggle.TextColor3 = Color3.new(1, 1, 1)
		BallToggle.ZIndex = 6
		Instance.new("UICorner", BallToggle).CornerRadius = UDim.new(0, 6)

		local modeOn = false
		local bv = nil

		BallToggle.MouseButton1Click:Connect(function()
			local hrp = char and char:FindFirstChild("HumanoidRootPart")
			if not hrp then return end

			modeOn = not modeOn

			if modeOn then
				BallToggle.Text = "Modo Bola: ON"
				targetSpeed = 0
				targetJump = 0

				bv = Instance.new("BodyVelocity")
				bv.MaxForce = Vector3.new(math.huge, 0, math.huge)
				bv.Velocity = hrp.CFrame.LookVector * 50
				bv.Parent = hrp

				task.spawn(function()
					local tempoInicio = os.clock()
					local velAtual = 50

					while modeOn and bv and hrp do
						local look = hrp.CFrame.LookVector
						local dirAtual = bv.Velocity.Unit

						-- Verifica o quanto o player está virando (Dot Product)
						-- Se o valor for próximo de 1, está reto. Se for menor, está fazendo curva.
						local alinhamento = look:Dot(dirAtual)

						if alinhamento < 0.95 then
							-- Faz curva: perde velocidade rápido
							velAtual = math.max(50, velAtual - 5)
						else
							-- Anda reto: acelera gradualmente até o limite de 200
							local tempoDecorrido = math.min(os.clock() - tempoInicio, 3)
							local targetVel = 50 + (tempoDecorrido / 3) * 150
							if velAtual < targetVel then
								velAtual = math.min(velAtual + 2, targetVel)
							end
						end

						bv.Velocity = Vector3.new(look.X * velAtual, 0, look.Z * velAtual)
						task.wait(0.05)
					end
				end)
			else
				BallToggle.Text = "Modo Bola: OFF"
				targetSpeed = 10
				targetJump = 60
				if bv then bv:Destroy() end
			end
		end)

		table.insert(activeLoops, {Disconnect = function() 
			BallToggle:Destroy() 
			if bv then bv:Destroy() end
		end})

	elseif alienName == "Bolha Tecnica" then
		targetSpeed = 20
		targetJump = 25
		workspace.Gravity = originalGravity / 6

		local vehicleButtons = {}
		local cdImpulso, cdPulo = false, false

		local function cleanupVehicle()
			for _, btn in pairs(vehicleButtons) do btn:Destroy() end
			vehicleButtons = {}
			workspace.Gravity = originalGravity / 6 -- Mantém gravidade reduzida geral
		end

		local checkSeat = RunService.Heartbeat:Connect(function()
			local hum = char and char:FindFirstChild("Humanoid")
			local seat = hum and hum.SeatPart

			if seat and seat:IsA("VehicleSeat") then
				-- Restaura gravidade normal enquanto sentado
				workspace.Gravity = originalGravity

				if #vehicleButtons == 0 then
					local bNames = {"Impulso", "Pulo"}
