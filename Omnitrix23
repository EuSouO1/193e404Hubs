-- Função para registrar os cliques do combo
local function registerComboClick(arrow)
	local now = os.clock()

	-- Reseta se ficar parado 5 segundos
	if now - lastComboClickTime > 5 then
		comboHistory = ""
	end
	lastComboClickTime = now

	comboHistory = comboHistory .. arrow

	if string.len(comboHistory) > 30 then
		comboHistory = string.sub(comboHistory, -30)
	end

	-- 1. VERIFICAÇÃO DE DESBLOQUEIO (Prioridade)
	for nome, codigo in pairs(COMBINACOES_ALIENS) do
		-- Verifica se o final do histórico é exatamente o código
		if string.sub(comboHistory, -string.len(codigo)) == codigo then
			if not AliensDesbloqueadosPeloJogador[nome] then
				AliensDesbloqueadosPeloJogador[nome] = true
				comboHistory = "" -- Zera para não ativar duas vezes

				shoutInChat("DNA de " .. nome .. " Desbloqueado")

				-- Efeito Visual
				local corAntiga = MainPanel.BackgroundColor3
				MainPanel.BackgroundColor3 = CORES_PAINEL.DnaDetec

				task.spawn(function()
					task.wait(1)
					MainPanel.BackgroundColor3 = corAntiga
					pcall(function() playSound(IDS.Sons.Recarregar) end)
				end)
				return -- Sai da função pois o alien foi desbloqueado
			end
		end
	end

	-- 2. CHECA CONTROLE MESTRE (Só se não desbloqueou nada)
	if comboHistory:sub(-30) == "><>><<<>>><<<<>>><><>><<<>>><<<" then
		comboHistory = ""
		masterControlActive = true
		MainPanel.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
		pcall(function() playSound(IDS.Sons.Carregado) end)
		if isTransformed then
			SelectionPanel.Visible = true
			OmnitrixBtn.Visible = false
		end
	end
end

OmnitrixBtn.MouseButton1Click:Connect(function()
	-- Se estiver na fila de transformação do protótipo, computa cliques insanos
	if isTransformingQueue then
		transformClicksDuringDelay = transformClicksDuringDelay + 1
		return
	end

	-- Se o controle mestre estiver ativo, pode abrir o menu de boas mesmo transformado
	if (omnitrixCooldown or ConfigsMenu.Visible) or (isTransformed and not masterControlActive) then return end

	local now = os.clock()
	if now - lastClickTime < 0.4 then
		clickCount = clickCount + 1
	else
		clickCount = 1
	end
	lastClickTime = now

	if clickCount >= 10 and not isTransformed then
		local randomAlien = IDS.Silhuetas[math.random(1, #IDS.Silhuetas)].Nome
		transform(randomAlien)
		clickCount = 0
		return
	end

	isOmnitrixOn = not isOmnitrixOn
	if isOmnitrixOn then
		pcall(function() playSound(IDS.Sons.Ligando) end)
		SelectionPanel.Visible = true
		OmnitrixBtn.Visible = false
		updateSilhouette()
	else
		SelectionPanel.Visible = false
		OmnitrixBtn.Visible = true
	end
end)

