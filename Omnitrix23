-- === SISTEMA DE DNA SCAN ===
local dnaConnections = {}

local function ativarDnaScan()
	if isTransformed or dnaScanActive then return end
	dnaScanActive = true

	local char = lplayer.Character
	if not char then return end

	-- Limpa conexões antigas
	for _, conn in pairs(dnaConnections) do
		conn:Disconnect()
	end
	dnaConnections = {}

	for _, part in pairs(char:GetDescendants()) do
		if part:IsA("BasePart") then
			local conn = part.Touched:Connect(function(hit)
				if not dnaScanActive then return end

				local model = hit:FindFirstAncestorOfClass("Model")
				local hum = model and model:FindFirstChildOfClass("Humanoid")

				if hum and model ~= char then
					-- Lógica de busca: Prioridade para TextBox no NameGUI, senão usa o nome do Model
					local head = model:FindFirstChild("Head")
					local gui = head and head:FindFirstChild("NameGUI")
					local textBox = gui and gui:FindFirstChild("TextBox")

					local nomeAlvoParaValidar = (textBox and textBox:IsA("TextLabel")) and textBox.Text or model.Name

					for nomeAlien, _ in pairs(COMBINACOES_ALIENS) do
						local busca = string.lower(string.gsub(nomeAlien, "%s+", ""))
						local alvoLimpo = string.lower(string.gsub(nomeAlvoParaValidar, "%s+", ""))

						if string.find(alvoLimpo, busca) then
							-- DNA Encontrado!
							dnaScanActive = false
							omnitrixCooldown = true
							MainPanel.BackgroundColor3 = CORES_PAINEL.DnaDetec
							pcall(function() playSound(IDS.Sons.Trocar) end)

							task.wait(5)

							AliensDesbloqueadosPeloJogador[nomeAlien] = true
							shoutInChat("DNA de " .. nomeAlien .. " Desbloqueado")

							omnitrixCooldown = false
							MainPanel.BackgroundColor3 = CORES_PAINEL.Carregado
							pcall(function() playSound(IDS.Sons.Recarregar) end)
							break
						end
					end
				end
			end)
			table.insert(dnaConnections, conn)
		end
	end
end

local function getAliensDisponiveis()
	local lista = {}
	-- Adiciona todos os primários
	for _, v in ipairs(IDS.Silhuetas) do table.insert(lista, v) end

	-- Adiciona os secundários APENAS se estiverem desbloqueados
	for _, v in ipairs(AliensSecundarios) do
		if AliensDesbloqueadosPeloJogador[v.Nome] then
			table.insert(lista, v)
		end
	end
	return lista
end

-- === LÓGICA DE TRANSFORMAÇÃO ===
local function transform(alienName)
	if omnitrixCooldown or (isTransformed and not masterControlActive) then return end

	-- Dentro da função de transformar:
	dnaScanActive = false
	for _, conn in pairs(dnaConnections) do
		conn:Disconnect() -- Mata as conexões ativas imediatamente
	end
	dnaConnections = {}

	-- Se o Controle Mestre estiver ativado, ignora o delay e transforma direto (perfeito)
	if masterControlActive then
		isTransformed = true
		currentAlienActive = alienName
		MainPanel.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
		pcall(function() playSound(IDS.Sons.Transformar) end)
		shoutInChat(alienName)
		applyAlienPowers(alienName)

		task.spawn(function()
			local tempoPassado = 0
			while tempoPassado < 955 and isTransformed and currentAlienActive == alienName do
				task.wait(1)
				tempoPassado = tempoPassado + 1
			end
			if isTransformed and currentAlienActive == alienName then
				pcall(function() playSound(IDS.Sons.Descarregando) end)
				for i = 1, 20 do
					if not isTransformed or currentAlienActive ~= alienName then break end
					MainPanel.BackgroundColor3 = (MainPanel.BackgroundColor3 == Color3.fromRGB(0, 255, 0)) and CORES_PAINEL.Descarregaged or Color3.fromRGB(0, 255, 0)
					task.wait(0.25)
				end
				if isTransformed and currentAlienActive == alienName then
					isTransformed = false
					currentAlienActive = ""
					resetPlayerPhysics()
					omnitrixCooldown = true
					MainPanel.BackgroundColor3 = CORES_PAINEL.Descarregaged

					task.wait(240)

					omnitrixCooldown = false
					MainPanel.BackgroundColor3 = CORES_PAINEL.Carregado
					pcall(function() playSound(IDS.Sons.Recarregar) end)

					-- ADICIONE ISSO AQUI:
					ativarDnaScan() 
				end
			end
		end)
		return
	end

	-- [PROTÓTIPO MODO] - Sistema com delay de 0.5 segundos e risco de falha
	if isTransformingQueue then 
		-- Se já estiver na janela de delay, acumula cliques extras
		transformClicksDuringDelay = transformClicksDuringDelay + 1
		return 
	end

	isTransformingQueue = true
	transformClicksDuringDelay = 1 -- Conta o primeiro clique da ativação

	task.wait(0.5) -- Delay exigido de meio segundo

	isTransformingQueue = false

	-- Se o player deu mais de 10 cliques totais no intervalo, escolhe um alien aleatório
	local finalAlien = alienName
	if transformClicksDuringDelay > 10 then
		local randomIndex = math.random(1, #IDS.Silhuetas)
		finalAlien = IDS.Silhuetas[randomIndex].Nome
	end
	transformClicksDuringDelay = 0

	isTransformed = true
	currentAlienActive = finalAlien
	SelectionPanel.Visible = false
	OmnitrixBtn.Visible = true
	MainPanel.BackgroundColor3 = CORES_PAINEL.Transformado

	pcall(function() playSound(IDS.Sons.Transformar) end)

	shoutInChat(finalAlien)
	applyAlienPowers(finalAlien)

	task.spawn(function()
		local timeActive = math.random(120, 360) 
		local tempoEsperaPrincipal = timeActive - 5
		local tempoPassado = 0

		while tempoPassado < tempoEsperaPrincipal and isTransformed and currentAlienActive == finalAlien do
			task.wait(1)
			tempoPassado = tempoPassado + 1
		end

		if isTransformed and currentAlienActive == finalAlien then
			pcall(function() playSound(IDS.Sons.Descarregando) end)

			for i = 1, 20 do
				if not isTransformed or currentAlienActive ~= finalAlien then break end
				if MainPanel.BackgroundColor3 == CORES_PAINEL.Transformado or MainPanel.BackgroundColor3 == CORES_PAINEL.Carregado then
					MainPanel.BackgroundColor3 = CORES_PAINEL.Descarregaged
				else
					MainPanel.BackgroundColor3 = CORES_PAINEL.Carregado
				end
				task.wait(0.25)
			end

			if isTransformed and currentAlienActive == finalAlien then
				isTransformed = false
				currentAlienActive = ""

				resetPlayerPhysics()
				omnitrixCooldown = true
				MainPanel.BackgroundColor3 = CORES_PAINEL.Descarregaged

				task.wait(240)

				omnitrixCooldown = false
				MainPanel.BackgroundColor3 = CORES_PAINEL.Carregado
				pcall(function() playSound(IDS.Sons.Recarregar) end)

				-- ADICIONE ISSO AQUI:
				ativarDnaScan() 
			end
		end
	end)
end

