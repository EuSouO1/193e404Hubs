-- Função para registrar os cliques do combo
local function registerComboClick(arrow)
	local now = os.clock()

	-- Reseta se ficar parado 5 segundos
	if now - lastComboClickTime > 5 then
		comboHistory = ""
	end
	lastComboClickTime = now

	comboHistory = comboHistory .. arrow

	-- Mantém um limite para evitar estouro de memória
	if string.len(comboHistory) > 30 then
		comboHistory = string.sub(comboHistory, -30)
	end

	-- CHECA CONTROLE MESTRE
	-- Código: ><>><<<>>><<<<>>><><>><<<>>><<<"
	if comboHistory:sub(-30) == "><>><<<>>><<<<>>><><>><<<>>><<<" then
		comboHistory = "" -- Zera o histórico

		-- Ativa o controle mestre
		masterControlActive = true
		MainPanel.BackgroundColor3 = Color3.fromRGB(0, 255, 0)

		pcall(function() playSound(IDS.Sons.Carregado) end)

		-- Se estiver transformado, abre o menu para trocar de alien instantaneamente
		if isTransformed then
			SelectionPanel.Visible = true
			OmnitrixBtn.Visible = false
		end
	end
end

OmnitrixBtn.MouseButton1Click:Connect(function()
	if omnitrixCooldown == true then return end

	-- 1. Lógica de Evolução Suprema
	if isTransformed then
		local alienAtual = currentAlienActive
		local ehSupremo = string.find(alienAtual, "Supremo")

		-- Se já for supremo, destransforma normal
		if ehSupremo then
			transform(nil)
			OmnitrixBtn.Visible = true
			return
		end

		-- Se estiver transformado num alien que tem supremo e NÃO é supremo
		if Supremos[alienAtual] then
			local nomeSupremo = alienAtual .. " Supremo"

			-- Usa o shoutInChat como solicitado (já coloca maiúsculo e !)
			shoutInChat(nomeSupremo)

			-- Aplica a nova forma
			currentAlienActive = nomeSupremo
			applyAlienPowers(nomeSupremo)
			return
		end

		-- Se não for nenhum dos casos acima, apenas destransforma
		transform(nil)
		OmnitrixBtn.Visible = true
		return
	end

	-- 2. Se não estiver transformado, alterna o estado do menu (código original)
	isOmnitrixOn = not isOmnitrixOn

	if isOmnitrixOn then
		pcall(function() playSound(IDS.Sons.Ligando) end)
		SelectionPanel.Visible = true
		OmnitrixBtn.Visible = false
		updateSilhouette()
	else
		SelectionPanel.Visible = false
		OmnitrixBtn.Visible = true
	end
end)

