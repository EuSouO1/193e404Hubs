RunService.Heartbeat:Connect(function()
	local agora = os.clock()
	local delta = agora - ultimaAtualizacao
	ultimaAtualizacao = agora

	if isTransformed then
		-- Se está transformado, consome o tempo
		if TempoRestanteDeTransformacao > 0 then
			TempoRestanteDeTransformacao = TempoRestanteDeTransformacao - delta
		else
			-- Tempo acabou: Destransforma forçadamente
			isTransformed = false
			currentAlienActive = nil
			resetPlayerPhysics()
			estaRecarregando = true
			omnitrixCooldown = true
			MainPanel.BackgroundColor3 = CORES_PAINEL.Descarregaged -- Fica vermelho
			pcall(function() playSound(IDS.Sons.Destransformando) end)
		end
	elseif estaRecarregando then
		-- Se está descarregado, regenera o tempo
		if TempoRestanteDeTransformacao < 480 then
			-- +2 a cada 1 segundo (usando delta * 2)
			TempoRestanteDeTransformacao = math.min(TempoRestanteDeTransformacao + (delta * 2), 480)
		else
			estaRecarregando = false
			omnitrixCooldown = false
			MainPanel.BackgroundColor3 = CORES_PAINEL.Carregado -- Volta pro verde
			pcall(function() playSound(IDS.Sons.Recarregar) end)
		end
	end
end)

local function iniciarAutoDestruicao()
	if omnitrixCooldown then return end

	isOmnitrixOn = false
	SelectionPanel.Visible = false
	OmnitrixBtn.Visible = true
	omnitrixCooldown = true
	masterControlActive = false 

	MainPanel.BackgroundColor3 = CORES_PAINEL.AutoDestruicao

	local TimerLbl = Instance.new("TextLabel", ScreenGui)
	TimerLbl.Size = UDim2.new(0, 300, 0, 50)
	TimerLbl.Position = UDim2.new(0.5, -150, 0.1, 0)
	TimerLbl.TextColor3 = Color3.new(1,0,0); TimerLbl.TextSize = 40;
	TimerLbl.ZIndex = 6
	TimerLbl.BackgroundTransparency = 1

	for i = 20, 1, -1 do
		TimerLbl.Text = "AUTO-DESTRUIÇÃO: " .. i
		pcall(function() playSound(IDS.Sons.Descarregando) end)
		task.wait(1)
	end

	TimerLbl:Destroy()
	resetPlayerPhysics()
	ScreenGui:Destroy()

	local char = lplayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if hrp then
		local randomDirection = Vector3.new(math.random(-100, 100), math.random(10, 100), math.random(-100, 100)).Unit
		local att = Instance.new("Attachment", hrp)
		local linVel = Instance.new("LinearVelocity")
		linVel.Attachment0 = att
		linVel.MaxForce = math.huge 
		linVel.VectorVelocity = randomDirection * 250
		linVel.Parent = hrp
		task.wait(0.1)
		linVel:Destroy()
		att:Destroy()
	end
end

-- Função auxiliar para limpar e validar a mensagem (reutilizando a lógica que criamos)
local function validarComandoAutoDestruicao(msg)
	-- 1. Transforma em minúsculo
	local msgLimpa = string.lower(msg)

	-- 2. Remove todos os caracteres que NÃO são letras (a-z) ou espaços
	-- Isso elimina automaticamente acentos, til, cedilha, hífens e pontuação
	msgLimpa = string.gsub(msgLimpa, "[^a-z%s]", "")

	-- 3. Remove espaços extras para garantir que a frase fique compacta
	msgLimpa = string.gsub(msgLimpa, "%s+", "")

	-- 4. Agora a busca fica muito mais fácil
	-- "ativar modo de auto-destruição" vira "ativarmododeautodestruicao"
	return string.find(msgLimpa, "ativarmododeautodestruicao")
end

-- Monitoramento do SEU chat (jogador local)
lplayer.Chatted:Connect(function(msg)
	if validarComandoAutoDestruicao(msg) then
		iniciarAutoDestruicao()
	end
end)

-- Monitoramento do chat dos OUTROS jogadores próximos
Players.PlayerAdded:Connect(function(player)
	player.Chatted:Connect(function(msg)
		if validarComandoAutoDestruicao(msg) then
			-- Verifica se o seu personagem e o do outro jogador existem e têm HRP
			local meuChar = lplayer.Character
			local outroChar = player.Character

			if meuChar and outroChar and meuChar:FindFirstChild("HumanoidRootPart") and outroChar:FindFirstChild("HumanoidRootPart") then
				local dist = (meuChar.HumanoidRootPart.Position - outroChar.HumanoidRootPart.Position).Magnitude
				if dist <= 20 then
					iniciarAutoDestruicao()
				end
			end
		end
	end)
end)

-- Opcional: Monitorar os jogadores que já estão no servidor quando o script iniciar
for _, player in pairs(Players:GetPlayers()) do
	if player ~= lplayer then
		player.Chatted:Connect(function(msg)
			if validarComandoAutoDestruicao(msg) then
				local char = lplayer.Character
				local otherChar = player.Character
				if char and otherChar and char:FindFirstChild("HumanoidRootPart") and otherChar:FindFirstChild("HumanoidRootPart") then
					if (char.HumanoidRootPart.Position - otherChar.HumanoidRootPart.Position).Magnitude <= 20 then
						iniciarAutoDestruicao()
					end
				end
			end
		end)
	end
end

-- === LÓGICA DE TRANSFORMAÇÃO ===
local function transform(alienName)
	-- 1. Bloqueia se estiver recarregando ou sem tempo
	if estaRecarregando or TempoRestanteDeTransformacao <= 0 then
		return 
	end

	-- 2. Destransformação manual (O tempo para de descer aqui)
	if isTransformed and currentAlienActive ~= "" then
		isTransformed = false
		currentAlienActive = nil
		resetPlayerPhysics()
		pcall(function() playSound(IDS.Sons.Destransformando) end) 
		return 
	end

	-- 3. Inicia Transformação
	isTransformed = true
	currentAlienActive = alienName

	SelectionPanel.Visible = false
	OmnitrixBtn.Visible = true
	MainPanel.BackgroundColor3 = CORES_PAINEL.Carregado

	pcall(function() playSound(IDS.Sons.Transformar) end)
	shoutInChat(alienName)
	applyAlienPowers(alienName)
end

