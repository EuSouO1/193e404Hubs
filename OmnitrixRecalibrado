				if atmosphere then atmosphere.Density = originalDensity end
			end

			for _, p in pairs(workspace:GetDescendants()) do
				if p:IsA("Highlight") and p.Name == "BlitzWolferESP" then p:Destroy() end
			end
		end})

	elseif alienName == "Gigante" then
		targetSpeed = 100
		targetJump = 175
	
	elseif alienName == "Mega-Olhos" then
		targetSpeed = 24
		targetJump = 67

		-- Loop de visão Raio-X (ESP em qualquer objeto atrás de paredes)
		local megaEspActive = true
		local megaESPThread = task.spawn(function()
			while megaEspActive do
				if char and char:FindFirstChild("HumanoidRootPart") then
					local cam = workspace.CurrentCamera
					local myPos = cam.CFrame.Position

					-- Escaneia todos os objetos no workspace
					for _, p in pairs(workspace:GetDescendants()) do
						-- Filtra apenas peças sólidas e ignora o próprio personagem
						if p:IsA("BasePart") and not p:IsDescendantOf(char) and p.Transparency < 1 then
							local dist = (p.Position - char.HumanoidRootPart.Position).Magnitude

							if dist <= 150 then
								-- Verifica se há obstáculo entre a câmera e o objeto
								local ray = Ray.new(myPos, (p.Position - myPos).Unit * dist)
								local hit, pos = workspace:FindPartOnRayWithIgnoreList(ray, {char})

								-- Se o Raycast colidir com algo que não é o objeto (ou um descendant dele), está atrás de obstáculo
								if hit and not hit:IsDescendantOf(p.Parent) and not p:IsDescendantOf(hit) then
									if not p:FindFirstChild("MegaESP") then
										local hl = Instance.new("Highlight", p)
										hl.Name = "MegaESP"
										hl.FillColor = Color3.fromRGB(255, 100, 0)
										hl.FillTransparency = 0.5
										hl.OutlineTransparency = 0.5
									end
								else
									-- Se estiver visível (sem obstáculo), remove o ESP
									if p:FindFirstChild("MegaESP") then p.MegaESP:Destroy() end
								end
							else
								-- Fora de alcance, remove
								if p:FindFirstChild("MegaESP") then p.MegaESP:Destroy() end
							end
						end
					end
				end
				task.wait(0.5) -- Delay para não pesar o script
			end
		end)

		table.insert(activeLoops, {Disconnect = function() 
			megaEspActive = false
			task.cancel(megaESPThread)
			-- Limpeza geral ao sair
			for _, p in pairs(workspace:GetDescendants()) do
				if p.Name == "MegaESP" then p:Destroy() end
			end
		end})
		
	elseif alienName == "Feedback" then
		targetSpeed = 30
		targetJump = 72

		-- Criação do botão de habilidade
		local SkillBtn = Instance.new("TextButton", ScreenGui)
		SkillBtn.Size = UDim2.new(0, 130, 0, 40)
		SkillBtn.Position = UDim2.new(0.85, -20, 0.35, 0)
		SkillBtn.Text = "Impulso de Energia"
		SkillBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
		SkillBtn.TextColor3 = Color3.new(1, 1, 1)
		SkillBtn.ZIndex = 6
		Instance.new("UICorner", SkillBtn)

		local cdImpulso = false

		SkillBtn.MouseButton1Click:Connect(function()
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if hrp and not cdImpulso then
				cdImpulso = true

				-- Cria o impulso
				local bv = Instance.new("BodyVelocity")
				bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
				bv.Velocity = (hrp.CFrame.LookVector * 200) + Vector3.new(0, 50, 0)
				bv.Parent = hrp

				-- Duração de 0.1 segundos
				task.wait(0.1)
				if bv then bv:Destroy() end

				-- Cooldown de 10 segundos
				task.wait(10)

				cdImpulso = false
			end
		end)

		-- Limpeza ao sair da forma
		table.insert(activeLoops, {Disconnect = function() 
			SkillBtn:Destroy() 
		end})
		
	elseif alienName == "Alien A" then
		targetSpeed = 100
		targetJump = 100

	elseif alienName == "FrankenStrike" then
		targetSpeed = 25
		targetJump = 75

		local ChargeBtn = Instance.new("TextButton", ScreenGui)
		ChargeBtn.Size = UDim2.new(0, 140, 0, 40)
		ChargeBtn.Position = UDim2.new(0.85, -20, 0.35, 0)
		ChargeBtn.Text = "Carregar Raio"
		ChargeBtn.BackgroundColor3 = Color3.fromRGB(68, 93, 60)
		ChargeBtn.TextColor3 = Color3.new(1, 1, 1)
		ChargeBtn.ZIndex = 6
		Instance.new("UICorner", ChargeBtn).CornerRadius = UDim.new(0, 6)

		-- Círculo de Raio (usando Decal para parecer um círculo no chão)
		local rangeIndicator = Instance.new("Part")
		rangeIndicator.Shape = Enum.PartType.Cylinder
		rangeIndicator.Size = Vector3.new(0.1, 1, 1)
		rangeIndicator.Anchored = true
		rangeIndicator.CanCollide = false
		rangeIndicator.Transparency = 1 -- Invisível inicialmente
		rangeIndicator.Color = Color3.fromRGB(68, 93, 60)
		rangeIndicator.Parent = workspace

		-- Adiciona um Decal para ser o "círculo" que aparece no chão
		local circleDecal = Instance.new("Decal", rangeIndicator)
		circleDecal.Texture = "rbxassetid://625907409" -- Textura padrão de círculo do Roblox
		circleDecal.Face = Enum.NormalId.Top

		local tempoInicio = 0
		local carregando = false

		-- Loop para seguir o player e atualizar tamanho
		local updateLoop = RunService.RenderStepped:Connect(function()
			if carregando and char and char:FindFirstChild("HumanoidRootPart") then
				local duracao = math.min(os.clock() - tempoInicio, 10)
				local raio = 25 + (duracao / 10) * 175

				rangeIndicator.Transparency = 0.5
				-- Rotação de 90 graus apenas no eixo Y (o segundo argumento)
				rangeIndicator.CFrame = char.HumanoidRootPart.CFrame * CFrame.new(0, -2.99, 0) * CFrame.Angles(0, 0, math.rad(90))
				rangeIndicator.Size = Vector3.new(0.1, raio * 2, raio * 2)
			else
				rangeIndicator.Transparency = 1
			end
		end)

		ChargeBtn.MouseButton1Down:Connect(function()
			tempoInicio = os.clock()
			carregando = true
			targetSpeed = 0
			targetJump = 0
		end)

		ChargeBtn.MouseButton1Up:Connect(function()
			carregando = false
			local duracao = math.min(os.clock() - tempoInicio, 10)
			local alcance = 25 + (duracao / 10) * 175

			targetSpeed = 25
			targetJump = 75

			for _, item in pairs(workspace:GetDescendants()) do
				if item:IsA("Tool") and item.Parent ~= char and item:FindFirstChild("Handle") then
					local dist = (item.Handle.Position - char.HumanoidRootPart.Position).Magnitude
					if dist <= alcance then
						local hl = Instance.new("Highlight", item)
						hl.FillColor = Color3.fromRGB(150, 0, 200)
						hl.FillTransparency = 0.2
						task.spawn(function()
							for i = 1, 30 do
								task.wait(0.1)
								hl.FillTransparency = 0.2 + (i/30 * 0.8)
							end
							hl:Destroy()
						end)
					end
				end
			end
		end)

		table.insert(activeLoops, {Disconnect = function() 
			ChargeBtn:Destroy() 
			rangeIndicator:Destroy()
			updateLoop:Disconnect()
		end})
	end

	if not isCustomSpeedLoop then
		local attributeProtector = RunService.Heartbeat:Connect(function()
			if hum and hum.Parent then
				if hum.WalkSpeed ~= targetSpeed then
					hum.WalkSpeed = targetSpeed
				end
				if hum.JumpPower ~= targetJump then
					hum.JumpPower = targetJump
				end
				if hum.UseJumpPower == false then
					hum.UseJumpPower = true
				end
			end
		end)
		table.insert(activeLoops, attributeProtector)
	end
end

local function iniciarAutoDestruicao()
	if omnitrixCooldown then return end

	isOmnitrixOn = false
	SelectionPanel.Visible = false
	OmnitrixBtn.Visible = true
	omnitrixCooldown = true
	masterControlActive = false 

	MainPanel.BackgroundColor3 = CORES_PAINEL.AutoDestruicao

	local TimerLbl = Instance.new("TextLabel", ScreenGui)
	TimerLbl.Size = UDim2.new(0, 300, 0, 50)
	TimerLbl.Position = UDim2.new(0.5, -150, 0.1, 0)
	TimerLbl.TextColor3 = Color3.new(1,0,0); TimerLbl.TextSize = 40;
	TimerLbl.ZIndex = 6
	TimerLbl.BackgroundTransparency = 1

	for i = 20, 1, -1 do
		TimerLbl.Text = "AUTO-DESTRUIÇÃO: " .. i
		pcall(function() playSound(IDS.Sons.Descarregando) end)
		task.wait(1)
	end

	TimerLbl:Destroy()
	resetPlayerPhysics()
	ScreenGui:Destroy()

	local char = lplayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if hrp then
		local randomDirection = Vector3.new(math.random(-100, 100), math.random(10, 100), math.random(-100, 100)).Unit
		local att = Instance.new("Attachment", hrp)
		local linVel = Instance.new("LinearVelocity")
		linVel.Attachment0 = att
		linVel.MaxForce = math.huge 
		linVel.VectorVelocity = randomDirection * 250
		linVel.Parent = hrp
		task.wait(0.1)
		linVel:Destroy()
		att:Destroy()
	end
end

-- Função auxiliar para limpar e validar a mensagem (reutilizando a lógica que criamos)
local function validarComandoAutoDestruicao(msg)
	-- 1. Transforma em minúsculo
	local msgLimpa = string.lower(msg)

	-- 2. Remove todos os caracteres que NÃO são letras (a-z) ou espaços
	-- Isso elimina automaticamente acentos, til, cedilha, hífens e pontuação
	msgLimpa = string.gsub(msgLimpa, "[^a-z%s]", "")

	-- 3. Remove espaços extras para garantir que a frase fique compacta
	msgLimpa = string.gsub(msgLimpa, "%s+", "")

	-- 4. Agora a busca fica muito mais fácil
	-- "ativar modo de auto-destruição" vira "ativarmododeautodestruicao"
	return string.find(msgLimpa, "ativarmododeautodestruicao")
end

-- Monitoramento do SEU chat (jogador local)
lplayer.Chatted:Connect(function(msg)
	if validarComandoAutoDestruicao(msg) then
		iniciarAutoDestruicao()
	end
end)

-- Monitoramento do chat dos OUTROS jogadores próximos
Players.PlayerAdded:Connect(function(player)
	player.Chatted:Connect(function(msg)
		if validarComandoAutoDestruicao(msg) then
			-- Verifica se o seu personagem e o do outro jogador existem e têm HRP
			local meuChar = lplayer.Character
			local outroChar = player.Character

			if meuChar and outroChar and meuChar:FindFirstChild("HumanoidRootPart") and outroChar:FindFirstChild("HumanoidRootPart") then
				local dist = (meuChar.HumanoidRootPart.Position - outroChar.HumanoidRootPart.Position).Magnitude
				if dist <= 20 then
					iniciarAutoDestruicao()
				end
			end
		end
	end)
end)

-- Opcional: Monitorar os jogadores que já estão no servidor quando o script iniciar
for _, player in pairs(Players:GetPlayers()) do
	if player ~= lplayer then
		player.Chatted:Connect(function(msg)
			if validarComandoAutoDestruicao(msg) then
				local char = lplayer.Character
				local otherChar = player.Character
				if char and otherChar and char:FindFirstChild("HumanoidRootPart") and otherChar:FindFirstChild("HumanoidRootPart") then
					if (char.HumanoidRootPart.Position - otherChar.HumanoidRootPart.Position).Magnitude <= 20 then
						iniciarAutoDestruicao()
					end
				end
			end
		end)
	end
end

-- === LÓGICA DE TRANSFORMAÇÃO ===
local function transform(alienName)
	-- Lógica de destransformação manual (clique no ícone enquanto transformado)
	if isTransformed and currentAlienActive ~= "" then
		isTransformed = false
		currentAlienActive = ""
		resetPlayerPhysics()
		MainPanel.BackgroundColor3 = CORES_PAINEL.Descarregaged
		pcall(function() playSound(IDS.Sons.Descarregando) end)
		return -- Sai da função aqui, não inicia nova transformação
	end

	if omnitrixCooldown or isTransformed then return end

	-- Transformação Instantânea (Removido o sistema de fila/delay)
	isTransformed = true
	currentAlienActive = alienName

	SelectionPanel.Visible = false
	OmnitrixBtn.Visible = true
	MainPanel.BackgroundColor3 = Color3.fromRGB(0, 255, 0)

	pcall(function() playSound(IDS.Sons.Transformar) end)
	shoutInChat(alienName)
	applyAlienPowers(alienName)

	task.spawn(function()
		-- Duração de 8 minutos (480 segundos)
		local duracaoTotal = 480 
		local tempoPassado = 0

		while tempoPassado < duracaoTotal and isTransformed and currentAlienActive == alienName do
			task.wait(1)
			tempoPassado = tempoPassado + 1
		end

		-- Se ainda estiver transformado após o tempo, inicia a desativação
		if isTransformed and currentAlienActive == alienName then
			pcall(function() playSound(IDS.Sons.Descarregando) end)

			-- Efeito de piscar antes de sair
			for i = 1, 10 do
				if not isTransformed then break end
				MainPanel.BackgroundColor3 = (MainPanel.BackgroundColor3 == Color3.fromRGB(0, 255, 0)) and CORES_PAINEL.Descarregaged or Color3.fromRGB(0, 255, 0)
				task.wait(0.3)
			end

			if isTransformed and currentAlienActive == alienName then
				isTransformed = false
				currentAlienActive = ""
				resetPlayerPhysics()

				-- Recarga de 4 minutos (240 segundos)
				omnitrixCooldown = true
				MainPanel.BackgroundColor3 = CORES_PAINEL.Descarregaged

				task.wait(240) 

				omnitrixCooldown = false
				MainPanel.BackgroundColor3 = CORES_PAINEL.Carregado
				pcall(function() playSound(IDS.Sons.Recarregar) end)
			end
		end
	end)
end

